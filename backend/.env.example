# Option A: full connection string (password must be URL-encoded if it contains @ # % etc.)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/?retryWrites=true&w=majority

# Option B: split values — password is encoded automatically (good for special characters)
# MONGO_USER=myuser
# MONGO_PASSWORD=your-plain-password
# MONGO_CLUSTER_HOST=cvd.xxxxx.mongodb.net

MONGO_DB_NAME=cvd_db
CORS_ORIGINS=http://localhost:3000
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
TESSDATA_PREFIX=C:\Program Files\Tesseract-OCR\tessdata
HOST=127.0.0.1
PORT=5000
FLASK_DEBUG=true

# Admin portal (set a long random ADMIN_TOKEN; use same token in Authorization after login)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
ADMIN_TOKEN=generate-a-long-random-secret-string
